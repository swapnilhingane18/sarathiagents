# ==============================================
# SARATHI Loan Backend — Environment Variables
# ==============================================
# Copy this file to .env and fill in your values.
# NEVER commit your real .env to GitHub!
# ==============================================

# --- Gemini AI (FREE) ---
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Server ---
PORT=5000

# --- CORS ---
# Set to your frontend URL (e.g. http://localhost:3000)
ALLOWED_ORIGIN=http://localhost:3000

# --- Future Integrations (leave as placeholders for now) ---
# TODO CIBIL: Get from https://www.cibil.com/developer
CIBIL_API_KEY=your_cibil_api_key_here

# TODO UIDAI: Get from https://uidai.gov.in/api
UIDAI_API_KEY=your_uidai_api_key_here
